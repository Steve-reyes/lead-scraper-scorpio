# ── Backend ──

# HTTP API server port
PORT=4000

# WebSocket server port (separate from HTTP)
WS_PORT=4001

# Chrome DevTools Protocol endpoint
# (Chromium running in headless mode on the VPS)
CHROME_CDP_URL=ws://127.0.0.1:3012

# ── Frontend ──

# Backend API URL for the frontend
NEXT_PUBLIC_API_URL=http://localhost:4000

# Backend WebSocket port for the frontend
NEXT_PUBLIC_WS_PORT=4001
